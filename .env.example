# Copy this file to .env.local for local development, and set the same variable
# in your Vercel project (Settings -> Environment Variables) for production.
#
# The server reads this EXACT name. The key is only ever used server-side
# (in app/api/chat/route.js) and is never exposed to the browser.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: override the default model (defaults to claude-opus-4-8).
# ANTHROPIC_MODEL=claude-opus-4-8
